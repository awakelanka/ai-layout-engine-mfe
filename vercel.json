{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' http://localhost:* https://ai-layout-engine-mfe.vercel.app/"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "ALLOW-FROM https://ai-layout-engine-mfe.vercel.app/"
                }
            ]
        }
    ]
}