{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' http://localhost:* https://awakelabs.in"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "ALLOW-FROM https://awakelabs.in"
                }
            ]
        }
    ]
}